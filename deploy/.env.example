# Public origin
APP_BASE_URL=https://reviews.example.com

# PostgreSQL backing service used by deploy/docker-compose.yml
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg://notebooklens:change-me@postgres:5432/notebooklens

# Shared required application configuration
SESSION_SECRET=replace-with-a-long-random-secret
ENCRYPTION_KEY=replace-with-a-long-random-encryption-key
GITHUB_APP_ID=1234567
GITHUB_APP_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nreplace-me\n-----END PRIVATE KEY-----
GITHUB_WEBHOOK_SECRET=replace-with-a-long-random-secret
GITHUB_OAUTH_CLIENT_ID=replace-me
GITHUB_OAUTH_CLIENT_SECRET=replace-me
GITHUB_HOST_KIND=github_com
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_WEB_BASE_URL=https://github.com
GITHUB_ENTERPRISE_MIN_VERSION=3.20.0
REQUIRE_USER_GITHUB_TOKENS_FOR_MIRRORING=true
MIRROR_FALLBACK_TO_APP_AUTH=true
EMAIL_PROVIDER=resend
EMAIL_API_KEY=re_replace-me
EMAIL_FROM=NotebookLens <reviews@example.com>
SNAPSHOT_RETENTION_DAYS=90
MANAGED_REVIEW_BETA_ENABLED=true

# Managed workspace configuration
REVIEW_ASSET_STORAGE_DRIVER=database
REVIEW_ASSET_MAX_BYTES=2097152
REVIEW_ASSET_ALLOWED_MIME_TYPES=image/png,image/jpeg,image/gif
MANAGED_AI_UI_ENABLED=true
MANAGED_AI_GATEWAY_KIND=litellm
GITHUB_PR_SYNC_ENABLED=true

# GitHub Enterprise Server example overrides:
# GITHUB_HOST_KIND=ghes
# GITHUB_API_BASE_URL=https://github.internal.example.com/api/v3
# GITHUB_WEB_BASE_URL=https://github.internal.example.com
